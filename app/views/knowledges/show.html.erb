<main class="inquiries-page knowledge-page">
  <nav class="page-nav">
    <%= link_to "承認済ナレッジ一覧へ戻る", knowledges_path %>
  </nav>

  <% if notice.present? %>
    <p class="flash flash-notice"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="flash flash-alert"><%= alert %></p>
  <% end %>

  <article class="inquiry-detail">
    <header class="page-header">
      <div>
        <div class="inquiry-card-meta">
          <span><%= @inquiry.category.name %></span>
          <time datetime="<%= @inquiry.created_at.iso8601 %>">
            <%= l @inquiry.created_at, format: :long %>
          </time>
        </div>
        <h1><%= @inquiry.title %></h1>
      </div>
      <% if current_user.admin? %>
        <div class="button-row">
          <%= link_to "編集", edit_inquiry_path(@inquiry), class: "button button-secondary" %>
          <%= button_to "削除", inquiry_path(@inquiry), method: :delete, class: "button button-danger", form: { data: { turbo_confirm: "削除してもよろしいですか？" } } %>
        </div>
      <% end %>
    </header>

    <div class="inquiry-body">
      <%= simple_format(@inquiry.body) %>
    </div>

    <section class="comments ms-5 mt-5">
    <h5>関連するやりとり・補足情報</h5>
    <p>コメント件数：<%= @comments.count %> 件</p>
      <% @comments.each do |comment| %>
        <div class="comment-item">
          <div class="comment-meta">
            <%= comment.user.role %>
            <time datetime="<%= comment.created_at.iso8601 %>">
              <%= l comment.created_at, format: :long %>
            </time>
          </div>

          <div class="comment-body">
            <%= simple_format(comment.body) %>
            <% if current_user.admin? %>
              <div class="comment-delete">
                <%= button_to "削除", inquiry_comment_path(@inquiry, comment), method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: "削除してもよろしいですか？" } } %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </section> 
        
    <% if current_user.admin? %>
      <section class="status-actions">
        <h2>ステータス更新</h2>
        <div class="button-row">
          <%= button_to "差し戻す", reject_inquiry_path(@inquiry), method: :patch, class: "button button-danger" %>
        </div>
      </section>
    <% end %>
  </article>
</main>

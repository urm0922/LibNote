<!DOCTYPE html>
<html>
  <head>
    <title>Libnote</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag('favicon.ico') %>
  </head>

  <body>
    <% if user_signed_in? %>
    <header class="header-nav">
      <div class="header-logo"><%= link_to root_path do %><%= image_tag "header-logo.png", alt: "LibNote" %><% end %></div>
      <div><%= link_to "トップ", root_path, class: "text-white nav-link" %></div>
      <div><%= link_to "問い合わせ作成", new_inquiry_path, class: "text-white nav-link" %></div>
      <div><%= link_to "問い合わせ一覧", inquiries_path, class: "text-white nav-link" %></div>
      <div><%= link_to "下書き一覧", confirm_inquiries_path, class: "text-white nav-link" %></div>
      <div><%= link_to "承認済ナレッジ一覧", knowledge_articles_path, class: "text-white nav-link" %></div>
      <div><%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-white nav-link" %></div>
      <div class="text-white nav-link"><%= "#{current_user.name} さん" %></div>
    </header>
    <% end %>
    <%= yield %>
  </body>
</html>

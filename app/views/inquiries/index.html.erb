<main class="inquiries-page">
  <header class="page-header">
    <div>
      <h1>問い合わせ一覧</h1>
      <p><%= @inquiries.size %>件の問い合わせ</p>
    </div>
    <%= link_to "新規作成", new_inquiry_path, class: "btn btn-primary" %>
  </header>
  <div class="search-form row mt-3 ms-3 align-self-end">
      <%= form_with url:inquiries_path, method: :get, local: true do |f| %>
        <%= f.text_field :q, value: params[:q], placeholder: "キーワード" %>
        <%= f.label :category_id, "カテゴリ" %>
        <%= f.collection_select :category_id, @categories, :id, :name, { prompt: "選択してください" } %>
        <%= f.label :status, "ステータス" %>
        <%= f.select :status, Inquiry.statuses.keys.map { |status| [I18n.t("enums.inquiry.status.#{status}"), status] }, { include_blank: "選択してください", selected: params[:status] } %>
        <%= f.submit "検索する", name: nil %>
        <%= link_to "条件クリア", inquiries_path, class: "btn btn-success"%>
      <% end %>
    </div>

  <% if notice.present? %>
    <p class="flash flash-notice"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="flash flash-alert"><%= alert %></p>
  <% end %>

  <% if @inquiries.any? %>
    <div class="inquiry-list">
      <% @inquiries.each do |inquiry| %>
        <article class="inquiry-card">
          <div class="inquiry-card-main">
            <div class="inquiry-card-meta">
              <span class="status-badge <%= inquiry_status_class(inquiry) %>">
                <%= inquiry_status_label(inquiry) %>
              </span>
              <span><%= inquiry.category.name %></span>
              <span><%= inquiry.user.name %></span>
              <time datetime="<%= inquiry.created_at.iso8601 %>">
                <%= l inquiry.created_at, format: :long %>
              </time>
            </div>
            <h2><%= link_to inquiry.title, inquiry_path(inquiry) %></h2>
            <p><%= truncate(inquiry.body, length: 120) %></p>
          </div>
          <%= link_to "詳細", inquiry_path(inquiry), class: "button button-secondary" %>
        </article>
      <% end %>
    </div>
  <% else %>
    <section class="empty-state">
      <h2>記事はまだありません</h2>
      <p>最初の問い合わせを作成できます。</p>
      <%= link_to "問い合わせを作成", new_inquiry_path, class: "button button-primary" %>
    </section>
  <% end %>
</main>

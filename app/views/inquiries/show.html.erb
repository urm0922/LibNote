<main class="inquiries-page">
  <nav class="page-nav">
    <%= link_to "一覧へ戻る", inquiries_path %>
  </nav>

  <% if notice.present? %>
    <p class="flash flash-notice"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="flash flash-alert"><%= alert %></p>
  <% end %>

  <article class="inquiry-detail">
    <header class="page-header">
      <div>
        <div class="inquiry-card-meta">
          <span class="status-badge <%= inquiry_status_class(@inquiry) %>">
            <%= inquiry_status_label(@inquiry) %>
          </span>
          <span><%= @inquiry.category.name %></span>
          <span><%= @inquiry.user.name %></span>
          <time datetime="<%= @inquiry.created_at.iso8601 %>">
            <%= l @inquiry.created_at, format: :long %>
          </time>
        </div>
        <h1><%= @inquiry.title %></h1>
      </div>
      <% if can_edit_inquiry?(@inquiry) %>
        <div class="button-row">
          <%= link_to "編集", edit_inquiry_path(@inquiry), class: "button button-secondary" %>
          <%= button_to "削除", inquiry_path(@inquiry), method: :delete, class: "button button-danger", form: { data: { turbo_confirm: "削除してもよろしいですか？" } } %>
        </div>
      <% end %>
    </header>

    <div class="inquiry-body">
      <%= simple_format(@inquiry.body) %>
    </div>

    <% if current_user.admin? || current_user.manager? %>
      <section class="status-actions">
        <h2>ステータス更新</h2>
        <div class="button-row">
          <%= button_to "回答済みにする", mark_as_answered_inquiry_path(@inquiry), method: :patch, class: "button button-secondary" %>
          <% if current_user.admin? %>
            <%= button_to "承認する", approve_inquiry_path(@inquiry), method: :patch, class: "button button-primary" %>
          <% end %>
          <%= button_to "差し戻す", reject_inquiry_path(@inquiry), method: :patch, class: "button button-danger" %>
        </div>
      </section>
    <% end %>
  </article>
</main>

<main class="auth-page">
  <section class="auth-panel">
    <h1>アカウント登録</h1>

    <%= form_with model: resource, scope: resource_name, url: registration_path(resource_name), class: "auth-form" do |form| %>
      <% if resource.errors.any? %>
        <section class="error-summary">
          <h2><%= resource.errors.count %>件のエラーがあります</h2>
          <ul>
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </section>
      <% end %>

      <div class="field">
        <%= form.label :name, "名前" %>
        <%= form.text_field :name, required: true, autofocus: true, autocomplete: "name" %>
      </div>

      <div class="field">
        <%= form.label :email, "メールアドレス" %>
        <%= form.email_field :email, required: true, autocomplete: "email" %>
      </div>

      <div class="field">
        <%= form.label :password, "パスワード" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password" %>
      </div>

      <div class="field">
        <%= form.label :password_confirmation, "パスワード確認" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
      </div>

      <div class="button-row">
        <%= form.submit "登録する", class: "button button-primary" %>
      </div>
    <% end %>

    <p class="auth-link">
      <%= link_to "ログインはこちら", new_session_path(resource_name) %>
    </p>
  </section>
</main>
